Meta.DisplayName=Hermes Agent
Meta.Description=Hermes Agent gateway with authenticated web dashboard, persistent state, and cron scheduling
Meta.OS=Linux
Meta.AarchSupport=Unknown
Meta.Arch=x86_64
Meta.Author=Antonia Guirao, lead developer
Meta.URL=https://hermes-agent.nousresearch.com/docs/
Meta.DisplayImageSource=
Meta.EndpointURIFormat=http://{ip}:{GenericModule.App.Ports.$ApplicationPort1}
Meta.ConfigManifest=hermes-agentconfig.json
Meta.MetaConfigManifest=
Meta.ConfigRoot=hermes-agent.kvp
Meta.MinAMPVersion=2.5.0.0
Meta.SpecificDockerImage=ghcr.io/cjguirao/amp-hermes-agent:latest
Meta.DockerRequired=True
Meta.DockerBaseReadOnly=False
Meta.ContainerPolicy=SupportedOnLinux
Meta.ContainerPolicyReason=Requires an AMP-compatible Linux image that provisions Hermes Agent into persistent instance storage. The dashboard stores and can modify provider keys, agent configuration, skills, sessions, cron jobs, and messaging settings, so it is always protected by authentication.
Meta.ExtraSetupStepsURI=https://hermes-agent.nousresearch.com/docs/user-guide/features/web-dashboard
Meta.Prerequisites=[]
Meta.ExtraContainerPackages=[]
Meta.ConfigReleaseState=NotSpecified
Meta.NoCommercialUsage=False
Meta.ConfigVersion=1.0
Meta.ReleaseNotes=Initial Hermes Agent template. Use AMP Update to check PyPI and install the selected Hermes Agent version into the persistent instance virtual environment.
Meta.BreakingReleaseNotes=
Meta.AppConfigId=5e5b1a79-1fd6-4c75-9ae7-7b3a3de4cbcb
Meta.ImportableExtensions=[]
App.DisplayName=Hermes Agent
App.RootDir=./hermes-agent/
App.BaseDirectory=./hermes-agent/
App.ExecutableWin=
App.ExecutableLinux=/usr/local/bin/hermes-amp-run
App.WorkingDir=.
App.LinuxCommandLineArgs=
App.WindowsCommandLineArgs=
App.CommandLineArgs=
App.UseLinuxIOREDIR=False
App.AppSettings={}
App.EnvironmentVariables={"HERMES_HOME":"/AMP/hermes-agent/.hermes","HERMES_AGENT_VERSION":"{{HermesAgentVersion}}","HERMES_DASHBOARD_PORT":"{{$ApplicationPort1}}","HERMES_DASHBOARD_BASIC_AUTH_USERNAME":"{{DashboardUsername}}","HERMES_DASHBOARD_BASIC_AUTH_PASSWORD":"{{DashboardPassword}}","HERMES_DASHBOARD_BASIC_AUTH_SECRET":"{{DashboardSessionSecret}}","API_SERVER_ENABLED":"{{EnableAPIServer}}","API_SERVER_HOST":"0.0.0.0","API_SERVER_PORT":"{{$ApplicationPort2}}","API_SERVER_KEY":"{{APIServerKey}}","API_SERVER_CORS_ORIGINS":"{{APIServerCORSOrigins}}","OPENROUTER_API_KEY":"{{OpenRouterApiKey}}","ANTHROPIC_API_KEY":"{{AnthropicApiKey}}","OPENAI_API_KEY":"{{OpenAIApiKey}}","OPENAI_BASE_URL":"{{OpenAIBaseUrl}}","GOOGLE_API_KEY":"{{GoogleApiKey}}","TZ":"{{Timezone}}"}
App.CommandLineParameterFormat=--{0} "{1}"
App.CommandLineParameterDelimiter=
App.ExitMethod=SIGTERM
App.ExitTimeout=45
App.ExitString=
App.ExitFile=app_exit.lck
App.HasWriteableConsole=False
App.HasReadableConsole=True
App.UDPLogger=False
App.SupportsLiveSettingsChanges=False
App.LiveSettingChangeCommandFormat=
App.ForceIPBinding=False
App.SupportsIPv6=False
App.ApplicationIPBinding=0.0.0.0
App.Ports=@IncludeJson[hermes-agentports.json]
App.AdminPortRef=0
App.PrimaryApplicationPortRef=ApplicationPort1
App.UniversalSleepApplicationUDPPortRef=0
App.UniversalSleepSteamQueryPortRef=0
App.MaxUsers=0
App.UseRandomAdminPassword=False
App.PersistRandomPassword=False
App.RemoteAdminPassword=
App.AdminMethod=STDIO
App.IgnoreSTDOUTAfterRCON=False
App.AdminLoginTransform=None
App.LoginTransformPrefix=
App.RCONConnectDelaySeconds=5
App.RCONConnectRetrySeconds=5
App.RCONHeartbeatMinutes=0
App.RCONHeartbeatCommand=
App.RCONSelectIPMethod=Default
App.TelnetLoginFormat={0}
App.UpdateSources=@IncludeJson[hermes-agentupdates.json]
App.PreStartStages=[]
App.UserActions=[]
App.ForceUpdate=False
App.ForceUpdateReason=
App.Compatibility=None
App.SteamUpdateAnonymousLogin=True
App.SteamForceLoginPrompt=False
App.RapidStartup=False
App.SmartExcludeExemptions=["*.cfg","*.conf","*.config","*.ini","*.json","*.xml","*.properties","*.kvp","*.yml","*.yaml","*.toml",".env","auth.json","SOUL.md","MEMORY.md","USER.md"]
App.SmartExcludeSupported=True
App.DumpFullChildProcessTree=False
App.MonitorChildProcessName=^supervisord$
App.MonitorDirectChildOnly=False
App.SupportsUniversalSleep=False
App.WakeupMode=Any
App.ApplicationReadyMode=RegexMatch
Console.FilterMatchRegex=
Console.FilterMatchReplacement=
Console.ThrowawayMessageRegex=^$
Console.AppReadyRegex=^.*(?:Uvicorn running on|Application startup complete|Gateway (?:started|running)|Scheduler started).*$
Console.UserJoinRegex=^$
Console.UserLeaveRegex=^$
Console.UserChatRegex=^$
Console.UpdateAvailableRegex=^$
Console.PreConnectRegex=
Console.ConnectIPRegex=
Console.MetricsRegex=
Console.HideFromConsoleRegex=
Console.SuppressLogAtStart=False
Console.UserActions={}
Limits.SleepMode=False
Limits.SleepOnStart=False
Limits.SleepDelayMinutes=5
Limits.DozeDelay=2
Limits.AutoRetryCount=2
Limits.SleepStartThresholdSeconds=45
